---
export const prerender = true;
import MainLayout from "../layouts/MainLayout.astro";
import { getAllUris, getNodeBySlug } from "../lib/api";
import Archive from "../templates/Archive.astro";
import Single from "../templates/Single.astro";
let uri = `/${Astro.params.uri}`;
if (Astro.url.searchParams.get("p")) {
  uri += `?p=${Astro.url.searchParams.get("p")}`;
}
console.log("uri", uri);
const data = await getNodeBySlug(uri);
const node = data.nodeByUri;

export async function getStaticPaths() {
  const allUris = await getAllUris();
  const slugs = Object.values(allUris)
    .reduce(function (acc, currentValue) {
      // @ts-ignore
      return acc.concat(currentValue.nodes);
    }, [])
    .map((node) => ({
      params: {
        slug: node.slug,
      },
    }));
  return slugs;
}

function resolveContentTemplate(node) {
  let template;
  switch (node.__typename) {
    case "Post":
      template = Single;
      break;
    case "Page":
      template = Single;
      break;
    case "Category":
      template = Archive;
      break;
    case "Tag":
      template = Archive;
      break;
    default:
      template = Single;
  }

  return template;
}

const Template = resolveContentTemplate(node);
---

<MainLayout title={node?.title || node?.name || ""} description={node?.excerpt}>
  <Template node={node} />
</MainLayout>
